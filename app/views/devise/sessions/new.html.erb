
<%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: {class: 'form-signin'}) do |f| %>

    <h2 class="text-center">Log in</h2>
    
    <%= f.input :email,
                required: false,
                autofocus: true,
                label: false,
                placeholder: "Enter Email here",
                input_html: { autocomplete: "email", class: 'form-control' } %>
    <%= f.input :password,
                required: false,
                label: false,
                placeholder: "Enter password here",
                input_html: { autocomplete: "current-password", class: 'form-control' } %>
    <%#= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
    <%= f.button :submit, "Log in", class: 'btn btn-primary btn-block' %>
<% end %>

<%= render "devise/shared/links" %>
